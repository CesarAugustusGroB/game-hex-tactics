{
  "amassCpBudget": 100,
  "rules": [
    { "when": { "isReserve": true, "threatened": true, "atDefensePos": true }, "do": "hold" },
    { "when": { "isReserve": true, "threatened": true }, "do": "defend" },
    { "when": { "homelandThreat": true }, "do": "repel" },
    { "when": { "raider": true }, "do": "raid" },
    { "when": { "groupType": "cavalry", "enemyInChargeRange": true }, "do": "charge" },
    { "when": { "groupType": "skirmisher", "enemyInPlay": true }, "do": "unleash" },
    { "when": { "groupType": "infantry", "holdsCentre": true }, "do": "hold" },
    { "when": { "canAmass": true, "cpSpentAmassingLt": 100 }, "do": "amass" },
    { "do": "march" }
  ],
  "combat": {
    "chargeReach": 5,
    "engageRange": 5,
    "homelandRepelThreshold": 6,
    "repelPerGroup": 6,
    "focusRadius": 4
  },
  "counter": {
    "vpWeight": 0.6,
    "pressureWeight": 0.4,
    "breacherWeight": 0.34,
    "raiderWeight": 0.17,
    "enemyCenterWeight": 0.3,
    "maxLaunchReduction": 0.75,
    "raidWatchRadius": 2
  },
  "strategy": {
    "raidDeficitFrac": 0.1,
    "raidGroups": 2,
    "centerFocusVpFrac": 0.3
  },
  "doctrines": {
    "balanced":   { "front": ["infantry", "cavalry", "skirmisher"], "reserve": "infantry" },
    "aggressive": { "front": ["cavalry", "infantry", "skirmisher"], "reserve": "cavalry" },
    "defensive":  { "front": ["skirmisher", "cavalry", "infantry"], "reserve": "skirmisher" }
  },
  "difficulties": {
    "easy":   { "reactionTicks": 12, "cpBudgetFrac": 0.5, "forceScale": 0.7, "capabilities": ["focusFire", "charge", "unleash", "raid", "defend", "repel", "earlyLaunch"] },
    "normal": { "reactionTicks": 6,  "cpBudgetFrac": 0.8, "forceScale": 0.7, "capabilities": ["charge"] },
    "hard":   { "reactionTicks": 2,  "cpBudgetFrac": 1.0, "forceScale": 0.7, "capabilities": [] },
    "test":   { "reactionTicks": 2,  "cpBudgetFrac": 1.0, "forceScale": 0.7, "capabilities": ["raid", "defend"] }
  }
}
